---
const services = [
  {
    icon: '&#9889;',
    title: 'Growth Strategy',
    description: 'Diseño la estrategia de crecimiento completa para tu empresa: canales, métricas, experimentos y roadmap de ejecución.',
    tags: ['Product-Led Growth', 'Go-to-Market', 'Funnel Optimization']
  },
  {
    icon: '&#9881;',
    title: 'AI Automation',
    description: 'Automatizo procesos repetitivos con IA: lead qualification, outreach personalizado, reporting y workflows operativos.',
    tags: ['Claude AI', 'Make/n8n', 'Custom Workflows']
  },
  {
    icon: '&#128640;',
    title: 'Revenue Operations',
    description: 'Conecto tu stack de ventas y marketing para crear un pipeline predecible. CRM, scoring, atribución y dashboards.',
    tags: ['GoHighLevel', 'CRM Setup', 'Pipeline Design']
  },
  {
    icon: '&#127919;',
    title: 'Paid & Organic Growth',
    description: 'Lanzo y optimizo campañas de adquisición. Google Ads, Meta, LinkedIn y estrategia de contenido con IA.',
    tags: ['Google Ads', 'LinkedIn Ads', 'Content Strategy']
  },
  {
    icon: '&#128202;',
    title: 'Analytics & Tracking',
    description: 'Implemento tracking completo y dashboards para que tomes decisiones basadas en datos, no intuición.',
    tags: ['GA4', 'GTM', 'Custom Dashboards']
  },
  {
    icon: '&#129302;',
    title: 'AI-Powered Outreach',
    description: 'Sistemas de prospección inteligente que califican, personalizan y envían mensajes a escala sin perder el toque humano.',
    tags: ['Lead Scoring', 'Email Sequences', 'Personalization']
  }
];
---

<section id="servicios" class="relative py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-purple-light">Servicios</p>
      <h2 class="mt-3 text-4xl font-bold tracking-tight text-white sm:text-5xl">
        Todo lo que necesitas para <span class="gradient-text">escalar</span>
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-gray-400">
        No vendo humo. Construyo sistemas que generan resultados medibles y sostenibles.
      </p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {services.map((service, i) => (
        <div class={`gradient-border card-hover p-6 animate-fade-in-up delay-${(i + 1) * 100}`}>
          <div class="relative z-10">
            <div class="text-3xl mb-4" set:html={service.icon} />
            <h3 class="text-lg font-semibold text-white">{service.title}</h3>
            <p class="mt-2 text-sm text-gray-400 leading-relaxed">{service.description}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {service.tags.map(tag => (
                <span class="rounded-full bg-purple/10 border border-purple/20 px-3 py-1 text-xs text-purple-light">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
