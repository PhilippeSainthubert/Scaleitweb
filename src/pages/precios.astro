---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const plans = [
  {
    name: 'Sprint',
    description: 'Proyecto puntual con entregable claro',
    price: 'Desde 1.500',
    unit: '/proyecto',
    features: [
      'Diagnóstico completo de tu funnel',
      'Estrategia de growth con roadmap',
      'Implementación de 1 sistema/automatización',
      'Setup de herramientas',
      'Documentación y handoff',
      '2 semanas de soporte post-entrega'
    ],
    cta: 'Empezar Sprint',
    highlighted: false
  },
  {
    name: 'Growth Partner',
    description: 'Acompañamiento mensual continuo',
    price: 'Desde 2.500',
    unit: '/mes',
    features: [
      'Todo lo del Sprint, más:',
      'Estrategia de growth continua',
      'Automatizaciones con IA ilimitadas',
      'Gestión de campañas paid',
      'Revenue ops y CRM management',
      'Dashboards y reporting semanal',
      'Reunión semanal de seguimiento',
      'Soporte prioritario por Slack'
    ],
    cta: 'Ser Growth Partner',
    highlighted: true
  },
  {
    name: 'Advisory',
    description: 'Consultoría estratégica para founders',
    price: 'Desde 500',
    unit: '/mes',
    features: [
      'Llamada mensual de 60 min',
      'Revisión de métricas y estrategia',
      'Recomendaciones accionables',
      'Acceso a frameworks y templates',
      'Soporte por email entre sesiones'
    ],
    cta: 'Agenda Advisory',
    highlighted: false
  }
];
---

<Layout title="Precios | Scale It">
  <Navbar />
  <main class="pt-32 pb-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-purple-light">Precios</p>
        <h1 class="mt-3 text-4xl font-bold text-white sm:text-5xl">Inversión <span class="gradient-text">transparente</span></h1>
        <p class="mx-auto mt-4 max-w-xl text-gray-400">
          Sin sorpresas. Cada propuesta se adapta a tus necesidades específicas.
        </p>
      </div>

      <div class="mt-16 grid gap-6 lg:grid-cols-3">
        {plans.map((plan) => (
          <div class={`gradient-border p-8 flex flex-col ${plan.highlighted ? 'glow' : ''}`}>
            <div class="relative z-10 flex flex-col flex-1">
              {plan.highlighted && (
                <div class="mb-4 inline-flex self-start items-center gap-2 rounded-full bg-purple/10 border border-purple/30 px-3 py-1 text-xs text-purple-light">
                  Más popular
                </div>
              )}
              <h3 class="text-2xl font-bold text-white">{plan.name}</h3>
              <p class="mt-1 text-sm text-gray-400">{plan.description}</p>

              <div class="mt-6">
                <span class="text-4xl font-bold text-white">{plan.price}€</span>
                <span class="text-gray-500">{plan.unit}</span>
              </div>

              <ul class="mt-8 space-y-3 flex-1">
                {plan.features.map((feature) => (
                  <li class="flex items-start gap-3 text-sm text-gray-400">
                    <svg class="h-5 w-5 flex-shrink-0 text-cyan" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>

              <a
                href="/#contacto"
                class={`mt-8 block rounded-xl py-3.5 text-center text-sm font-semibold transition-all hover:scale-[1.02] ${
                  plan.highlighted
                    ? 'bg-gradient-to-r from-purple to-cyan text-white hover:shadow-xl hover:shadow-purple/25'
                    : 'border border-white/10 bg-white/5 text-gray-300 hover:bg-white/10'
                }`}
              >
                {plan.cta} &rarr;
              </a>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-12 text-center">
        <p class="text-sm text-gray-500">
          Precios orientativos + IVA. Cada proyecto recibe una propuesta personalizada tras la llamada de diagnóstico.
        </p>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
