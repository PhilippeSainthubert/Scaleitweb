---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const testimonials = [
  {
    name: 'Carlos M.',
    role: 'CEO, Fintech SaaS',
    text: 'Philippe nos ayudó a pasar de 0 a un sistema de lead generation automatizado en 3 semanas. El pipeline se triplicó en el primer trimestre.',
    rating: 5
  },
  {
    name: 'Laura G.',
    role: 'Head of Growth, B2B Platform',
    text: 'Lo que más valoro es que no vende humo. Te dice exactamente qué va a hacer, lo ejecuta rápido y los resultados hablan solos.',
    rating: 5
  },
  {
    name: 'Marcos R.',
    role: 'Founder, MarTech Startup',
    text: 'Las automatizaciones con IA que implementó nos ahorraron 20+ horas semanales en tareas operativas. Game changer para un equipo pequeño.',
    rating: 5
  },
  {
    name: 'Ana P.',
    role: 'CMO, Health Tech',
    text: 'El diagnóstico inicial fue brutal. En 30 minutos identificó 3 problemas críticos en nuestro funnel que llevábamos meses sin ver.',
    rating: 5
  },
  {
    name: 'Diego S.',
    role: 'COO, EdTech',
    text: 'Contratamos a Philippe para montar todo el stack de revenue ops. CRM, scoring, dashboards, todo integrado y funcionando en un mes.',
    rating: 5
  },
  {
    name: 'Patricia V.',
    role: 'Growth Lead, Logistics SaaS',
    text: 'Las campañas de paid que gestionó tuvieron un ROAS 4x desde el primer mes. Sabe lo que hace y se nota la experiencia.',
    rating: 5
  }
];
---

<Layout title="Testimonios | Scale It">
  <Navbar />
  <main class="pt-32 pb-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-purple-light">Testimonios</p>
        <h1 class="mt-3 text-4xl font-bold text-white sm:text-5xl">Lo que dicen mis <span class="gradient-text">clientes</span></h1>
        <p class="mx-auto mt-4 max-w-xl text-gray-400">
          Resultados reales de empresas tech que han escalado con Scale It.
        </p>
      </div>

      <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {testimonials.map((t) => (
          <div class="gradient-border card-hover p-6">
            <div class="relative z-10">
              <!-- Stars -->
              <div class="flex gap-1 text-yellow-400 mb-4">
                {Array.from({length: t.rating}).map(() => (
                  <svg class="h-4 w-4 fill-current" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <p class="text-gray-300 leading-relaxed text-sm italic">"{t.text}"</p>
              <div class="mt-4 pt-4 border-t border-white/5">
                <p class="font-semibold text-white text-sm">{t.name}</p>
                <p class="text-xs text-gray-500">{t.role}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-16 text-center">
        <a
          href="/#contacto"
          class="inline-flex rounded-full bg-gradient-to-r from-purple to-cyan px-8 py-3.5 text-base font-semibold text-white transition-all hover:shadow-xl hover:shadow-purple/25 hover:scale-105"
        >
          Quiero resultados así &rarr;
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
