---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Política de Cookies | Scale It">
  <Navbar />
  <main class="pt-32 pb-20">
    <div class="mx-auto max-w-3xl px-6">
      <h1 class="text-4xl font-bold text-white">Política de <span class="gradient-text">Cookies</span></h1>
      <p class="mt-2 text-sm text-gray-500">Última actualización: 27 de marzo de 2026</p>

      <div class="mt-10 space-y-8 text-gray-400 leading-relaxed">
        <section>
          <h2 class="text-xl font-semibold text-white mb-3">1. ¿Qué son las cookies?</h2>
          <p>
            Las cookies son pequeños archivos de texto que se almacenan en tu dispositivo cuando visitas
            un sitio web. Nos ayudan a mejorar tu experiencia de navegación y a entender cómo interactúas
            con nuestra web.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-semibold text-white mb-3">2. Cookies que utilizamos</h2>

          <div class="mt-4 overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-white/10">
                  <th class="text-left py-3 pr-4 text-gray-300 font-semibold">Cookie</th>
                  <th class="text-left py-3 pr-4 text-gray-300 font-semibold">Tipo</th>
                  <th class="text-left py-3 pr-4 text-gray-300 font-semibold">Finalidad</th>
                  <th class="text-left py-3 text-gray-300 font-semibold">Duración</th>
                </tr>
              </thead>
              <tbody>
                <tr class="border-b border-white/5">
                  <td class="py-3 pr-4 text-purple-light">cookie_consent</td>
                  <td class="py-3 pr-4">Técnica</td>
                  <td class="py-3 pr-4">Almacena tu preferencia de cookies</td>
                  <td class="py-3">12 meses</td>
                </tr>
                <tr class="border-b border-white/5">
                  <td class="py-3 pr-4 text-purple-light">_vercel_insights</td>
                  <td class="py-3 pr-4">Analítica</td>
                  <td class="py-3 pr-4">Métricas de rendimiento (Vercel Speed Insights)</td>
                  <td class="py-3">Sesión</td>
                </tr>
                <tr class="border-b border-white/5">
                  <td class="py-3 pr-4 text-purple-light">va</td>
                  <td class="py-3 pr-4">Analítica</td>
                  <td class="py-3 pr-4">Vercel Analytics - visitas y páginas vistas</td>
                  <td class="py-3">24 horas</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <section>
          <h2 class="text-xl font-semibold text-white mb-3">3. Tipos de cookies</h2>
          <ul class="space-y-3">
            <li>
              <strong class="text-gray-300">Técnicas (necesarias):</strong> Son imprescindibles para el funcionamiento
              de la web. No requieren consentimiento.
            </li>
            <li>
              <strong class="text-gray-300">Analíticas:</strong> Nos permiten medir el tráfico y analizar el
              comportamiento de los usuarios para mejorar nuestros servicios.
            </li>
          </ul>
        </section>

        <section>
          <h2 class="text-xl font-semibold text-white mb-3">4. Gestión de cookies</h2>
          <p>
            Puedes aceptar o rechazar las cookies a través del banner que aparece al visitar nuestra web.
            También puedes configurar tu navegador para bloquear o eliminar cookies:
          </p>
          <ul class="mt-2 list-disc list-inside space-y-1">
            <li><a href="https://support.google.com/chrome/answer/95647" target="_blank" rel="noopener noreferrer" class="text-purple-light hover:underline">Google Chrome</a></li>
            <li><a href="https://support.mozilla.org/es/kb/cookies-informacion-que-los-sitios-web-almacenan-en-" target="_blank" rel="noopener noreferrer" class="text-purple-light hover:underline">Mozilla Firefox</a></li>
            <li><a href="https://support.apple.com/es-es/guide/safari/sfri11471/mac" target="_blank" rel="noopener noreferrer" class="text-purple-light hover:underline">Safari</a></li>
            <li><a href="https://support.microsoft.com/es-es/microsoft-edge/eliminar-las-cookies-en-microsoft-edge-63947406-40ac-c3b8-57b9-2a946a29ae09" target="_blank" rel="noopener noreferrer" class="text-purple-light hover:underline">Microsoft Edge</a></li>
          </ul>
        </section>

        <section>
          <h2 class="text-xl font-semibold text-white mb-3">5. Contacto</h2>
          <p>
            Si tienes alguna duda sobre nuestra política de cookies, puedes contactarnos en
            <a href="mailto:philosh95@gmail.com" class="text-purple-light hover:underline">philosh95@gmail.com</a>.
          </p>
        </section>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
