---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="404 — Página no encontrada | Scale It">
  <Navbar />
  <main class="relative min-h-screen flex items-center justify-center radial-glow pt-20">
    <div class="relative z-10 mx-auto max-w-xl px-6 text-center">
      <div class="text-8xl font-extrabold gradient-text animate-fade-in-up">404</div>
      <h1 class="animate-fade-in-up delay-100 mt-4 text-2xl font-bold text-white">Página no encontrada</h1>
      <p class="animate-fade-in-up delay-200 mt-3 text-gray-400">
        Parece que esta ruta no existe. Pero tranquilo, tu crecimiento sí tiene ruta.
      </p>
      <div class="animate-fade-in-up delay-300 mt-8 flex flex-col gap-3 sm:flex-row sm:justify-center">
        <a
          href="/"
          class="rounded-full bg-gradient-to-r from-purple to-cyan px-8 py-3.5 text-base font-semibold text-white transition-all hover:shadow-xl hover:shadow-purple/25 hover:scale-105"
        >
          &larr; Volver al inicio
        </a>
        <a
          href="/#contacto"
          class="rounded-full border border-white/10 bg-white/5 px-8 py-3.5 text-base font-medium text-gray-300 transition-all hover:bg-white/10"
        >
          Contactar
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
