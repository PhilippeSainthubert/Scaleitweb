---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Gracias | Scale It">
  <Navbar />
  <main class="relative min-h-screen flex items-center justify-center radial-glow pt-20">
    <!-- Decorative elements -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-purple/5 rounded-full blur-3xl animate-float"></div>
      <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-cyan/5 rounded-full blur-3xl animate-float" style="animation-delay: -3s;"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-2xl px-6 text-center">
      <!-- Success icon -->
      <div class="animate-fade-in-up mx-auto mb-8 flex h-24 w-24 items-center justify-center rounded-full bg-gradient-to-br from-purple/20 to-cyan/20 border border-purple/30 glow">
        <svg class="h-12 w-12 text-cyan" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
        </svg>
      </div>

      <h1 class="animate-fade-in-up delay-100 text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
        Mensaje <span class="gradient-text">recibido!</span>
      </h1>

      <p class="animate-fade-in-up delay-200 mt-6 text-lg text-gray-400 leading-relaxed">
        Gracias por contactar con Scale It. He recibido tu solicitud y te responderé
        en menos de <span class="text-white font-semibold">24 horas</span>.
      </p>

      <div class="animate-fade-in-up delay-300 mt-8 gradient-border p-6">
        <div class="relative z-10">
          <p class="text-sm text-gray-400">Mientras tanto, puedes:</p>
          <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:justify-center">
            <a
              href="https://www.linkedin.com/in/philippesainthubert/"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-full border border-white/10 bg-white/5 px-5 py-2.5 text-sm text-gray-300 transition-all hover:bg-white/10 hover:border-white/20"
            >
              Conectar en LinkedIn &nearr;
            </a>
            <a
              href="https://www.youtube.com/@Marketingdetrasdelclick"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-full border border-white/10 bg-white/5 px-5 py-2.5 text-sm text-gray-300 transition-all hover:bg-white/10 hover:border-white/20"
            >
              Ver YouTube &nearr;
            </a>
            <a
              href="https://x.com/Mktgdtrdelclick"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-full border border-white/10 bg-white/5 px-5 py-2.5 text-sm text-gray-300 transition-all hover:bg-white/10 hover:border-white/20"
            >
              Seguir en X &nearr;
            </a>
          </div>
        </div>
      </div>

      <a
        href="/"
        class="animate-fade-in-up delay-400 mt-10 inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-purple to-cyan px-8 py-3.5 text-base font-semibold text-white transition-all hover:shadow-xl hover:shadow-purple/25 hover:scale-105"
      >
        <span>&larr;</span> Volver al inicio
      </a>
    </div>
  </main>
  <Footer />
</Layout>
