---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Blog | Scale It">
  <Navbar />
  <main class="pt-32 pb-20">
    <div class="mx-auto max-w-3xl px-6">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-purple-light">Blog</p>
        <h1 class="mt-3 text-4xl font-bold text-white sm:text-5xl">Growth <span class="gradient-text">Insights</span></h1>
        <p class="mx-auto mt-4 max-w-xl text-gray-400">
          Estrategias, frameworks y lecciones de growth para empresas tech.
        </p>
      </div>

      <div class="mt-20 text-center">
        <div class="gradient-border p-12">
          <div class="relative z-10">
            <div class="text-5xl mb-4">&#128640;</div>
            <h2 class="text-xl font-semibold text-white">Coming soon</h2>
            <p class="mt-2 text-gray-400">
              Estoy preparando contenido de alto valor sobre growth, IA y automatización.
              Mientras tanto, sígueme en mis redes para no perderte nada.
            </p>
            <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:justify-center">
              <a
                href="https://www.youtube.com/@Marketingdetrasdelclick"
                target="_blank"
                rel="noopener noreferrer"
                class="rounded-full border border-white/10 bg-white/5 px-5 py-2.5 text-sm text-gray-300 transition-all hover:bg-white/10"
              >
                YouTube &nearr;
              </a>
              <a
                href="https://www.linkedin.com/in/philippesainthubert/"
                target="_blank"
                rel="noopener noreferrer"
                class="rounded-full border border-white/10 bg-white/5 px-5 py-2.5 text-sm text-gray-300 transition-all hover:bg-white/10"
              >
                LinkedIn &nearr;
              </a>
              <a
                href="https://x.com/Mktgdtrdelclick"
                target="_blank"
                rel="noopener noreferrer"
                class="rounded-full border border-white/10 bg-white/5 px-5 py-2.5 text-sm text-gray-300 transition-all hover:bg-white/10"
              >
                X &nearr;
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
