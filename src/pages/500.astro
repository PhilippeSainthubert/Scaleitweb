---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Error del servidor | Scale It">
  <Navbar />
  <main class="relative min-h-screen flex items-center justify-center radial-glow pt-20">
    <div class="relative z-10 mx-auto max-w-xl px-6 text-center">
      <div class="text-8xl font-extrabold gradient-text animate-fade-in-up">500</div>
      <h1 class="animate-fade-in-up delay-100 mt-4 text-2xl font-bold text-white">Algo salió mal</h1>
      <p class="animate-fade-in-up delay-200 mt-3 text-gray-400">
        Estamos trabajando para solucionarlo. Por favor, inténtalo de nuevo en unos minutos.
      </p>
      <a
        href="/"
        class="animate-fade-in-up delay-300 mt-8 inline-flex rounded-full bg-gradient-to-r from-purple to-cyan px-8 py-3.5 text-base font-semibold text-white transition-all hover:shadow-xl hover:shadow-purple/25 hover:scale-105"
      >
        &larr; Volver al inicio
      </a>
    </div>
  </main>
  <Footer />
</Layout>
